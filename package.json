{
  "name": "multiclaw",
  "version": "0.1.0",
  "description": "Manage multiple OpenClaw instances side by side",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c cyan,yellow \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsup --watch --onSuccess \"electron .\"",
    "build": "pnpm build:main && pnpm build:renderer",
    "build:main": "tsup",
    "build:renderer": "vite build",
    "dist": "pnpm build && electron-builder",
    "dist:mac": "pnpm build && electron-builder --mac",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "execa": "^9.6.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^8.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.28.0"
}
