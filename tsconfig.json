{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["app/shared/*"]
    }
  },
  "include": [
    "app/main/**/*",
    "app/preload/**/*",
    "app/instances/**/*",
    "app/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "app/renderer"
  ]
}
